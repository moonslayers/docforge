{
  "name": "docforge",
  "version": "1.0.0",
  "description": "Generador de documentación multi-proyecto — PDF desde Markdown con soporte multi-proyecto",
  "type": "module",
  "bin": {
    "docforge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check": "tsc --noEmit && eslint src/",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "md-to-pdf": "^5.2.4",
    "puppeteer-core": "^25.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "eslint": "^10.4.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.4"
  },
  "license": "MIT"
}
